# Django Settings
SECRET_KEY=test-key-123456789-abcde-12345
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - SQLite (за локално тестване, без PostgreSQL)
# Коментираме PostgreSQL настройките
# DB_NAME=djangoARExam
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# Celery - временно изключваме (за локално тестване)
# CELERY_BROKER_URL=memory://
# CELERY_RESULT_BACKEND=memory://
# REDIS_URL=memory://

# Email - временно изключваме (за локално тестване)
# CONTACT_EMAIL=test@example.com
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend